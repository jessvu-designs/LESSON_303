// Prisma schema for Universal Parking.
//
// Datasource: Postgres in all environments. For local dev a one-line
// `docker compose up -d db` (see repo root) spins up Postgres on
// localhost:5432. Set DATABASE_URL via apps/api/.env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())

  vehicles       ParkingVehicle[]
  sessions       ParkingSession[]
  paymentMethods PaymentMethod[]
  deviceTokens   DeviceToken[]
}

model PaymentMethod {
  id                    String  @id @default(cuid())
  userId                String
  stripePaymentMethodId String? @unique
  brand                 String  // 'visa' | 'mastercard' | 'amex' | 'discover' | 'apple_pay' | 'google_pay' | 'other'
  last4                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ParkingVehicle {
  id           String  @id @default(cuid())
  userId       String
  licensePlate String
  state        String?
  nickname     String?
  isDefault    Boolean @default(false)

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions ParkingSession[]

  @@index([userId])
}

model ParkingZone {
  id           String  @id
  cityId       String
  providerId   String
  code         String
  displayName  String
  address      String?
  latitude     Float?
  longitude    Float?
  // Rate
  hourlyCents  Int
  currency     String  @default("USD")
  flatFeeCents Int?
  // Rules
  maxSessionMinutes Int?
  allowsExtension   Boolean @default(true)
  rulesNotes        String?

  sessions ParkingSession[]
}

model ParkingSession {
  id              String   @id @default(cuid())
  userId          String
  vehicleId       String
  zoneId          String
  providerId      String
  startedAt       DateTime
  expiresAt       DateTime
  status          String   // 'active' | 'ended' | ...
  totalPaidCents  Int
  currency        String
  reminder15Sent  Boolean  @default(false)
  reminder5Sent   Boolean  @default(false)
  expiredSent     Boolean  @default(false)

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle ParkingVehicle    @relation(fields: [vehicleId], references: [id])
  zone    ParkingZone       @relation(fields: [zoneId], references: [id])
  extensions SessionExtension[]

  @@index([userId, status])
  @@index([userId, startedAt])
  @@index([status, expiresAt])
}

model SessionExtension {
  id             String   @id @default(cuid())
  sessionId      String
  addedMinutes   Int
  addedCostCents Int
  createdAt      DateTime @default(now())

  session ParkingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?  // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
